{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["donor", "ngo", "volunteer"] },
        "location": {
          "type": "object",
          "properties": {
            "latitude": { "type": "number" },
            "longitude": { "type": "number" }
          }
        },
        "rating": { "type": "number" },
        "ratingCount": { "type": "number" }
      },
      "required": ["uid", "email", "role"]
    },
    "Donation": {
      "title": "Donation",
      "description": "Item listed for donation",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "donorId": { "type": "string" },
        "donorName": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["food", "medicine"] },
        "expiryDate": { "type": "string", "format": "date-time" },
        "quantity": { "type": "string" },
        "location": {
          "type": "object",
          "properties": {
            "latitude": { "type": "number" },
            "longitude": { "type": "number" },
            "address": { "type": "string" }
          }
        },
        "status": { "type": "string", "enum": ["available", "pending", "collected"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "claimedById": { "type": "string" },
        "claimedByName": { "type": "string" },
        "qrCode": { "type": "string" }
      },
      "required": ["donorId", "title", "type", "expiryDate", "status"]
    },
    "Request": {
      "title": "Request",
      "description": "Request for food or medicine",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "requesterId": { "type": "string" },
        "requesterName": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["food", "medicine"] },
        "urgency": { "type": "string", "enum": ["low", "medium", "high"] },
        "location": {
          "type": "object",
          "properties": {
            "latitude": { "type": "number" },
            "longitude": { "type": "number" },
            "address": { "type": "string" }
          }
        },
        "status": { "type": "string", "enum": ["open", "fulfilled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["requesterId", "title", "type", "urgency", "status"]
    },
    "Chat": {
      "title": "Chat",
      "description": "Chat session between donor and receiver",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "participants": { "type": "array", "items": { "type": "string" } },
        "donationId": { "type": "string" },
        "requestId": { "type": "string" },
        "lastMessage": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["participants", "updatedAt"]
    },
    "Message": {
      "title": "Message",
      "description": "Chat message",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "chatId": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["chatId", "senderId", "text", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/donations/{donationId}": {
      "schema": "Donation",
      "description": "Donation listings"
    },
    "/requests/{requestId}": {
      "schema": "Request",
      "description": "Requests for items"
    },
    "/chats/{chatId}": {
      "schema": "Chat",
      "description": "Chat sessions"
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a chat"
    },
    "/test/{docId}": {
      "schema": { "type": "object", "properties": { "status": { "type": "string" } } },
      "description": "Connection test collection"
    }
  }
}
